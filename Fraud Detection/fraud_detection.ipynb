      "  Legitimate : 3,940\n",
      "  Fraud      : 394\n",
      "  Fraud rate : 9.1%\n",
      "\n",
      "✅ Training set rebalanced. Test set remains untouched (real-world ratio).\n"
     ]
    }
   ],
   "source": [
    "# --- Undersampling ---\n",
    "train_data = pd.concat([X_train, y_train], axis=1)\n",
    "\n",
    "legit_train = train_data[train_data['Class'] == 0]\n",
    "fraud_train = train_data[train_data['Class'] == 1]\n",
    "\n",
    "# Undersample legitimate to 10x the fraud count (keep some imbalance, more realistic)\n",
    "n_fraud = len(fraud_train)\n",
    "legit_undersampled = resample(legit_train, n_samples=n_fraud * 10,\n",
    "                               random_state=42, replace=False)\n",
    "\n",
    "balanced_train = pd.concat([legit_undersampled, fraud_train])\n",
    "X_train_bal = balanced_train[feature_cols]\n",
    "y_train_bal = balanced_train['Class']\n",
    "\n",
    "print(f'Balanced training set: {len(balanced_train):,} rows')\n",
    "print(f'  Legitimate : {(y_train_bal==0).sum():,}')\n",
    "print(f'  Fraud      : {(y_train_bal==1).sum():,}')\n",
    "print(f'  Fraud rate : {y_train_bal.mean()*100:.1f}%')\n",
    "print('\\n✅ Training set rebalanced. Test set remains untouched (real-world ratio).')"
   ]
