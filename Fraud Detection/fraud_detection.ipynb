   "source": [
    "# --- Fraud Over Time ---\n",
    "# Time is in seconds from first transaction in dataset\n",
    "df['Hour'] = (df['Time'] / 3600).astype(int) % 24\n",
    "\n",
    "hourly_fraud_rate = df.groupby('Hour').apply(\n",
    "    lambda x: x['Class'].sum() / len(x) * 100\n",
    ").reset_index()\n",
    "hourly_fraud_rate.columns = ['Hour', 'FraudRate']\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 4))\n",
    "\n",
    "# Volume by hour\n",
    "hour_counts = df.groupby(['Hour', 'Class']).size().unstack(fill_value=0)\n",
    "hour_counts.columns = ['Legitimate', 'Fraud']\n",
    "hour_counts['Legitimate'].plot(ax=axes[0], color='#2196F3', linewidth=2, label='Legitimate')\n",
    "ax2 = axes[0].twinx()\n",
    "hour_counts['Fraud'].plot(ax=ax2, color='#F44336', linewidth=2, linestyle='--', label='Fraud')\n",
    "axes[0].set_title('Transaction Volume by Hour of Day', fontweight='bold')\n",
    "axes[0].set_xlabel('Hour')\n",
    "axes[0].set_ylabel('Legitimate count', color='#2196F3')\n",
    "ax2.set_ylabel('Fraud count', color='#F44336')\n",
    "axes[0].set_xticks(range(0, 24, 2))\n",
    "\n",
    "# Fraud rate by hour\n",
    "axes[1].bar(hourly_fraud_rate['Hour'], hourly_fraud_rate['FraudRate'],\n",
    "            color='#FF7043', edgecolor='white')\n",
    "axes[1].set_title('Fraud Rate (%) by Hour of Day', fontweight='bold')\n",
    "axes[1].set_xlabel('Hour')\n",
    "axes[1].set_ylabel('Fraud Rate (%)')\n",
    "axes[1].yaxis.set_major_formatter(mtick.PercentFormatter(decimals=3))\n",
    "axes[1].set_xticks(range(0, 24, 2))\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "peak_hour = hourly_fraud_rate.loc[hourly_fraud_rate['FraudRate'].idxmax(), 'Hour']\n",
    "print(f'⚠️  Peak fraud rate occurs around hour {peak_hour}:00 — likely overnight when monitoring is lower.')"
