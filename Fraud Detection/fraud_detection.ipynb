    "# --- Feature Distributions: Which V-features separate fraud best? ---\n",
    "# Compare mean values of V1-V28 between fraud and legit\n",
    "v_features = [f'V{i}' for i in range(1, 29)]\n",
    "mean_diff = abs(fraud[v_features].mean() - legit[v_features].mean()).sort_values(ascending=False)\n",
