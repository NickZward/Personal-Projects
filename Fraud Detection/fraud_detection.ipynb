     "output_type": "stream",
     "text": [
      "\n",
      "✅ Best F1 threshold: 0.80\n",
      "   Precision: 0.745 | Recall: 0.837 | F1: 0.788\n"
     ]
    }
   ],
   "source": [
    "# --- Threshold Analysis (Random Forest) ---\n",
    "rf_probs = results['Random Forest']['y_prob']\n",
    "thresholds = np.arange(0.1, 0.9, 0.05)\n",
    "\n",
    "threshold_results = []\n",
    "for t in thresholds:\n",
    "    preds = (rf_probs >= t).astype(int)\n",
    "    cm = confusion_matrix(y_test, preds)\n",
    "    tn, fp, fn, tp = cm.ravel()\n",
    "    precision = tp / (tp + fp) if (tp + fp) > 0 else 0\n",
    "    recall = tp / (tp + fn) if (tp + fn) > 0 else 0\n",
    "    f1 = 2 * precision * recall / (precision + recall) if (precision + recall) > 0 else 0\n",
    "    threshold_results.append({\n",
    "        'Threshold': t,\n",
    "        'Precision': precision,\n",
    "        'Recall': recall,\n",
    "        'F1': f1,\n",
    "        'FP (false alarms)': fp,\n",
    "        'FN (missed fraud)': fn\n",
    "    })\n",
    "\n",
    "thr_df = pd.DataFrame(threshold_results)\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(13, 4))\n",
    "\n",
    "axes[0].plot(thr_df['Threshold'], thr_df['Precision'], 'b-o', markersize=4, label='Precision')\n",
    "axes[0].plot(thr_df['Threshold'], thr_df['Recall'], 'r-o', markersize=4, label='Recall')\n",
    "axes[0].plot(thr_df['Threshold'], thr_df['F1'], 'g-o', markersize=4, label='F1')\n",
    "axes[0].set_title('Precision / Recall / F1 vs Threshold', fontweight='bold')\n",
    "axes[0].set_xlabel('Decision Threshold')\n",
    "axes[0].legend()\n",
    "axes[0].axvline(0.5, color='gray', linestyle='--', alpha=0.5, label='Default (0.5)')\n",
    "\n",
    "axes[1].plot(thr_df['Threshold'], thr_df['FP (false alarms)'], 'b-o', markersize=4, label='False alarms')\n",
    "axes[1].plot(thr_df['Threshold'], thr_df['FN (missed fraud)'], 'r-o', markersize=4, label='Missed fraud')\n",
    "axes[1].set_title('False Alarms vs Missed Fraud by Threshold', fontweight='bold')\n",
    "axes[1].set_xlabel('Decision Threshold')\n",
    "axes[1].legend()\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "best_f1_row = thr_df.loc[thr_df['F1'].idxmax()]\n",
    "print(f'\\n✅ Best F1 threshold: {best_f1_row[\"Threshold\"]:.2f}')\n",
    "print(f'   Precision: {best_f1_row[\"Precision\"]:.3f} | Recall: {best_f1_row[\"Recall\"]:.3f} | F1: {best_f1_row[\"F1\"]:.3f}')"
